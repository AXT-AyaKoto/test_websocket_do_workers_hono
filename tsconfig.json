{
    "compilerOptions": {
        "target": "ESNext",
        "lib": [ "ESNext" ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "noEmit": true,
        "isolatedModules": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "worker-configuration.d.ts"
    ]
}
